{
  "expo": {
    "name": "Haushaltsbuch",
    "slug": "haushaltsbuch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.haushaltsbuch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Um Quittungen zu fotografieren",
        "NSPhotoLibraryUsageDescription": "Um Quittungen aus der Galerie zu wählen"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "de.haushaltsbuch.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      ["expo-camera", { "cameraPermission": "Um Quittungen zu fotografieren" }],
      ["expo-notifications", { "icon": "./assets/notification-icon.png" }]
    ],
    "scheme": "haushaltsbuch",
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
