{
  "expo": {
    "name": "Haushaltsbuch",
    "slug": "haushaltsbuch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.bernauer24.haushaltsbuch",
      "infoPlist": {
        "NSCameraUsageDescription": "Um Quittungen zu fotografieren",
        "NSPhotoLibraryUsageDescription": "Um Quittungen aus der Galerie zu wählen",
        "NSLocalNetworkUsageDescription": "Die App benötigt Zugriff auf das lokale Netzwerk, um eine Verbindung zum Entwicklungsserver herzustellen.",
        "NSBonjourServices": ["_http._tcp", "_https._tcp"],
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "37.27.193.27": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": false
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "de.haushaltsbuch.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Um Quittungen zu fotografieren"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "scheme": "haushaltsbuch",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
